############################
# AI Answers Generic Docker Template
############################

# Main LLM endpoint. Use an OpenAI-compatible chat completions endpoint.
LLM_PROVIDER=openai
LLM_URL=https://api.openai.com/v1/chat/completions
LLM_KEY=your_api_key
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.2

# Model resolver. Keep fixed unless you use a dynamic model gateway.
LLM_MODEL_MODE=fixed
LLM_MODEL_FALLBACK=gpt-4o-mini
LLM_MODELS_URL=
LLM_SWITCH_STATUS_URL=
LLM_MODEL_CACHE_SECONDS=60
LLM_MODEL_DISCOVERY_TIMEOUT=5
LLM_MODEL_VERIFY_SSL=true

# Plugin trigger behavior.
LLM_INTERACTIVE=true
LLM_QUESTION_MARK_REQUIRED=false
LLM_TABS=general,science,it
LLM_CONTEXT_DEEP_COUNT=5
LLM_CONTEXT_SHALLOW_COUNT=15
LLM_SYSTEM_PROMPT=

############################
# Embedding Retrieval
############################

EMBEDDING_ENABLED=false
EMBEDDING_URL=https://api.openai.com/v1/embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_FORMAT=openai
EMBEDDING_API_KEY=your_embedding_api_key_or_same_as_llm_key
EMBEDDING_API_KEY_HEADER=Authorization
EMBEDDING_API_KEY_SCHEME=Bearer
EMBEDDING_TOP_K=15

############################
# Rerank
############################

RERANK_ENABLED=false
RERANK_API_FORMAT=tei
RERANK_URL=http://host.docker.internal:8082/rerank
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_API_KEY=
RERANK_API_KEY_HEADER=Authorization
RERANK_API_KEY_SCHEME=Bearer
RERANK_TOP_K=8

############################
# Retrieval Runtime
############################

RETRIEVAL_CANDIDATE_COUNT=25
RETRIEVAL_DOCUMENT_MAX_CHARS=3000
RETRIEVAL_TIMEOUT=10
RETRIEVAL_VERIFY_SSL=true
