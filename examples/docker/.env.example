# Copy this file to .env and edit it before running Docker Compose.
# Do not commit real API keys, private domains, IP addresses, or internal URLs.

# -----------------------------------------------------------------------------
# SearXNG
# -----------------------------------------------------------------------------
SEARXNG_PORT=18080
SEARXNG_BASE_URL=http://localhost:18080/
SEARXNG_UWSGI_PROCESSES=4
SEARXNG_UWSGI_THREADS=4

# -----------------------------------------------------------------------------
# Core LLM endpoint
# -----------------------------------------------------------------------------
# The plugin uses an OpenAI-compatible chat completions endpoint.
LLM_PROVIDER=openai
LLM_KEY=replace-with-your-api-key
LLM_URL=https://api.example.com/v1/chat/completions
LLM_MODEL=example-chat-model

LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.2
LLM_CONTEXT_DEEP_COUNT=5
LLM_CONTEXT_SHALLOW_COUNT=15
LLM_TABS=general,science,it,news
LLM_INTERACTIVE=true
LLM_QUESTION_MARK_REQUIRED=false

# -----------------------------------------------------------------------------
# Model resolver
# -----------------------------------------------------------------------------
# fixed: always use LLM_MODEL
# auto: try to discover the active model from LLM_SWITCH_STATUS_URL or LLM_MODELS_URL
LLM_MODEL_MODE=fixed
LLM_MODEL_FALLBACK=example-chat-model

# Optional. Required only when LLM_MODEL_MODE=auto.
LLM_SWITCH_STATUS_URL=
LLM_MODELS_URL=https://api.example.com/v1/models
LLM_MODEL_CACHE_SECONDS=60
LLM_MODEL_DISCOVERY_TIMEOUT=5

# Leave empty to reuse LLM_KEY when supported by your deployment.
LLM_MODEL_API_KEY=
LLM_MODEL_API_KEY_HEADER=Authorization
LLM_MODEL_API_KEY_SCHEME=Bearer
LLM_MODEL_VERIFY_SSL=true

# -----------------------------------------------------------------------------
# Semantic retrieval / embeddings
# -----------------------------------------------------------------------------
# Disabled by default. Enable only after configuring an embeddings endpoint.
EMBEDDING_ENABLED=false
EMBEDDING_URL=https://api.example.com/v1/embeddings
EMBEDDING_MODEL=example-embedding-model
EMBEDDING_API_FORMAT=openai
EMBEDDING_API_KEY=
EMBEDDING_API_KEY_HEADER=Authorization
EMBEDDING_API_KEY_SCHEME=Bearer
EMBEDDING_TOP_K=15

# -----------------------------------------------------------------------------
# Optional reranker
# -----------------------------------------------------------------------------
# Supported formats include: tei, jina, cohere.
RERANK_ENABLED=false
RERANK_URL=https://api.example.com/v1/rerank
RERANK_MODEL=example-rerank-model
RERANK_API_FORMAT=cohere
RERANK_API_KEY=
RERANK_API_KEY_HEADER=Authorization
RERANK_API_KEY_SCHEME=Bearer
RERANK_TOP_K=8

# -----------------------------------------------------------------------------
# Retrieval tuning
# -----------------------------------------------------------------------------
RETRIEVAL_CANDIDATE_COUNT=25
RETRIEVAL_DOCUMENT_MAX_CHARS=3000
RETRIEVAL_TIMEOUT=10
RETRIEVAL_VERIFY_SSL=true
