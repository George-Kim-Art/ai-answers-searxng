# Ollama OpenAI-compatible API template
# Requires Ollama with OpenAI-compatible endpoints available on the host.
LLM_PROVIDER=ollama
LLM_URL=http://host.docker.internal:11434/v1/chat/completions
LLM_KEY=
LLM_MODEL=llama3.1
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.2

LLM_MODEL_MODE=fixed
LLM_MODEL_FALLBACK=llama3.1
LLM_MODELS_URL=http://host.docker.internal:11434/v1/models
LLM_MODEL_CACHE_SECONDS=60

EMBEDDING_ENABLED=false
EMBEDDING_URL=http://host.docker.internal:11434/v1/embeddings
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_FORMAT=openai
EMBEDDING_API_KEY=
EMBEDDING_TOP_K=15

RERANK_ENABLED=false
RERANK_API_FORMAT=tei
RERANK_URL=http://host.docker.internal:8082/rerank
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_API_KEY=
RERANK_TOP_K=8

RETRIEVAL_CANDIDATE_COUNT=25
RETRIEVAL_DOCUMENT_MAX_CHARS=3000
RETRIEVAL_TIMEOUT=10
RETRIEVAL_VERIFY_SSL=true

LLM_INTERACTIVE=true
LLM_QUESTION_MARK_REQUIRED=false
LLM_TABS=general,science,it
LLM_CONTEXT_DEEP_COUNT=5
LLM_CONTEXT_SHALLOW_COUNT=15
LLM_SYSTEM_PROMPT=
