# OneAPI / NewAPI OpenAI-compatible gateway template
LLM_PROVIDER=openai
LLM_URL=http://host.docker.internal:3000/v1/chat/completions
LLM_KEY=your_gateway_api_key
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.2

LLM_MODEL_MODE=auto
LLM_MODEL_FALLBACK=gpt-4o-mini
LLM_MODELS_URL=http://host.docker.internal:3000/v1/models
LLM_MODEL_API_KEY=your_gateway_api_key
LLM_MODEL_CACHE_SECONDS=60

EMBEDDING_ENABLED=true
EMBEDDING_URL=http://host.docker.internal:3000/v1/embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_FORMAT=openai
EMBEDDING_API_KEY=your_gateway_api_key
EMBEDDING_TOP_K=15

RERANK_ENABLED=false
RERANK_API_FORMAT=cohere
RERANK_URL=http://host.docker.internal:3000/v1/rerank
RERANK_MODEL=rerank-model-name
RERANK_API_KEY=your_gateway_api_key
RERANK_TOP_K=8

RETRIEVAL_CANDIDATE_COUNT=25
RETRIEVAL_DOCUMENT_MAX_CHARS=3000
RETRIEVAL_TIMEOUT=10
RETRIEVAL_VERIFY_SSL=false

LLM_INTERACTIVE=true
LLM_QUESTION_MARK_REQUIRED=false
LLM_TABS=general,science,it
LLM_CONTEXT_DEEP_COUNT=5
LLM_CONTEXT_SHALLOW_COUNT=15
LLM_SYSTEM_PROMPT=
